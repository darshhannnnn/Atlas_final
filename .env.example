# ATLAS Environment Configuration Template
# Copy this file to .env and fill in your values

# ============================================
# DATABASE (Vercel Postgres or PostgreSQL)
# ============================================
# For Vercel: Automatically set when you link Vercel Postgres
# For local: postgresql://user:password@localhost:5432/dbname
DATABASE_URL=postgresql://atlas:atlas123@localhost:5432/atlas_db

# ============================================
# REDIS (Upstash Redis or local Redis)
# ============================================
# For Upstash: Get from https://upstash.com
# For local: redis://localhost:6379
REDIS_URL=redis://localhost:6379

# ============================================
# SECURITY
# ============================================
# Generate a secure random string (min 32 characters)
# Example: openssl rand -hex 32
SECRET_KEY=your-secret-key-change-in-production-min-32-chars

# ============================================
# LLM API (Mistral AI)
# ============================================
# Get your API key from https://console.mistral.ai/
MISTRAL_API_KEY=your-mistral-api-key-here

# ============================================
# VERCEL BLOB STORAGE (for file uploads)
# ============================================
# Automatically set by Vercel when Blob is enabled
# Leave empty for local development (uses local filesystem)
BLOB_READ_WRITE_TOKEN=

# ============================================
# VECTOR DATABASE - Option 1: Pinecone
# ============================================
# Get your API key from https://www.pinecone.io/
# Recommended for Vercel serverless deployment
PINECONE_API_KEY=
PINECONE_ENVIRONMENT=us-east-1
PINECONE_INDEX_NAME=atlas-knowledge

# ============================================
# VECTOR DATABASE - Option 2: ChromaDB
# ============================================
# For local development only (not recommended for serverless)
USE_CHROMADB=false
CHROMA_DB_DIR=./chroma_db

# ============================================
# ENVIRONMENT
# ============================================
# Options: development, production
ENVIRONMENT=development

# ============================================
# OPTIONAL: Advanced Settings
# ============================================
# LLM_MODEL=mistral-small-latest
# LLM_TEMPERATURE=0.7
# LLM_MAX_TOKENS=2000
# MAX_RESPONSE_TIME=60
# MAX_FILE_SIZE=104857600
